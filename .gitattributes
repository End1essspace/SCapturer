# Default text normalization
* text=auto

# Windows source and build files
*.cs text eol=crlf
*.csproj text eol=crlf
*.props text eol=crlf
*.sln text eol=crlf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.wxs text eol=crlf
*.pubxml text eol=crlf
*.txt text eol=crlf

# Repository and documentation files
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.msi binary
*.exe binary
*.dll binary
